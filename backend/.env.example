# Cyber Guard backend environment template
APP_NAME=Cyber Guard Platform API
APP_ENV=dev
APP_DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cyber_guard
CORS_ORIGINS=http://localhost:5173

JWT_SECRET_KEY=CHANGE_ME_LOCAL_DEV_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=120

DEMO_ORG_ADMIN_PASSWORD=org-admin-demo
DEMO_PLATFORM_ADMIN_PASSWORD=platform-admin-demo

LOCAL_AI_ENABLED=true
API_AI_ENABLED=true
API_AI_PROVIDER_NAME=openai-compatible
API_AI_BASE_URL=
API_AI_KEY=

VIRUSTOTAL_ENABLED=true
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3
SOURCE_A_ENABLED=true
SOURCE_B_ENABLED=true
SOURCE_C_ENABLED=false

PUBLIC_THREATS_API_ENABLED=false
ADMIN_REVIEW_REQUIRED_FOR_EXTERNAL_REPORTS=true
